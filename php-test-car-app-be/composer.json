{
  "name": "joe-situ/php-test-car-app-be",
  "description": "Lumen backend service for Dinggo PHP test",
  "type": "project",
  "require": {
    "php": "^8.2",
    "laravel/lumen-framework": "^10.0",
    "vlucas/phpdotenv": "^5.6",
    "guzzlehttp/guzzle": "^7.9"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "test": "phpunit --colors=always"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
